# ===== 内容自动生产线配置 =====
# 复制本文件为 config.yaml，填入你的 API Key 等配置
# cp config.yaml.example config.yaml

# MiMo API (OpenAI 兼容格式)
mimo:
  api_key: "your-mimo-api-key"           # 替换为你的 MiMo API key
  base_url: "https://token-plan-cn.xiaomimimo.com/v1"
  model: "mimo-v2.5-pro"
  # TTS 语音合成配置（通过 chat completions 接口调用）
  tts_model: "mimo-v2.5-tts"              # 语音合成模型
  tts_voice: "Chloe"                       # 音色名称
  tts_voice_prompt: "用自然、亲切、有感染力的中文语调朗读，像一位专业的短视频口播博主。"
  # tts_base_url: "https://your-tts-endpoint/v1"  # TTS专用地址（默认同 base_url）

# 内容生成参数
generation:
  max_tokens: 4096
  temperature: 0.7
  # 每类别默认生成数量（道和术各生成几篇）
  default_limit: 1
  # 生成语言
  language: "zh-CN"
  # 自动生成配图
  auto_image: true
  # 自动生成视频（抖音等视频平台）
  auto_video: true
  # 是否自动给生成的视频添加字幕
  video_subtitles: true
  video_subtitle_font: "Microsoft YaHei"
  video_subtitle_size: 48
  video_subtitle_line_chars: 16
  video_subtitle_max_lines: 2

# Qwen-Image 生图配置（阿里云百炼）
dashscope:
  api_key: "your-dashscope-api-key"      # 替换为你的百炼 API Key
  base_url: "https://dashscope.aliyuncs.com/api/v1"
  model: "qwen-image-2.0-pro"            # 可选: qwen-image / qwen-image-plus / qwen-image-max / qwen-image-2.0-pro
  size: "1472*1104"                       # 图片分辨率
  # 图片保存目录
  media_dir: "media"
  # 文生视频配置（Wan2.7-T2V）
  video_model: "wan2.7-t2v"              # 可选: wan2.7-t2v / wan2.7-t2v-plus
  video_size: "1280*720"                  # 视频分辨率
  video_duration: 15                      # 视频时长(秒)

# 热点监控
monitor:
  # 每次采集的最大热点数（每个数据源）
  max_topics: 10
  # 数据源配置
  sources:
    # 道：社会热点数据源
    dao:
      - toutiao              # 今日头条热榜
    # 术：AI技术热点数据源
    shu:
      - 36kr                 # 36kr AI/科技快讯
      - hackernews           # Hacker News AI相关话题

# 发布平台配置
platforms:
  wechat:
    enabled: true                    # 是否启用该平台（内容生成 + 发布）
    app_id: "your-wechat-app-id"         # 微信公众号 AppID
    app_secret: "your-wechat-app-secret" # 微信公众号 AppSecret
    author: "作者名"                      # 作者名（不超过16字）
    # 发布模式: draft=存草稿, publish=直接发布
    mode: "draft"
    # 排版主题: claude / apple / wechat / notion
    theme: "claude"

  xiaohongshu:
    enabled: true                    # 是否启用该平台（内容生成 + 发布）
    # Playwright cookie 存储路径
    cookie_file: "db/xhs_cookies.json"
    # 是否无头模式（调试时设为 false）
    headless: false
    # 浏览器通道: chrome / msedge（使用系统已安装的浏览器）
    channel: "msedge"

  douyin:
    enabled: true                    # 是否启用该平台（内容生成 + 发布）
    # Playwright cookie 存储路径
    cookie_file: "db/douyin_cookies.json"
    # 是否无头模式
    headless: false
    # 浏览器通道: chrome / msedge（使用系统已安装的浏览器）
    channel: "msedge"
    # 发布后等待秒数（留给验证码/审核弹窗处理时间）
    post_publish_wait: 30

# 数据库
database:
  path: "db/pipeline.db"

# 日志
logging:
  level: "INFO"
  file: "db/pipeline.log"
